{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/api/health",
    "restartPolicy": {
      "type": "ON_FAILURE"
    },
    "healthcheckTimeout": 100
  },
  "variables": {
    "NODE_ENV": "production",
    "PORT": "3000"
  }
}