# ASF 激活码验证服务器配置
# 复制为 .env 并修改

# 服务器端口 (默认 3000)
PORT=3000

# 管理员 API 密钥 (必须修改！使用强密码)
ADMIN_API_KEY=change-me-to-secure-random-key-in-production

# 数据目录（默认项目内 data）
DATA_ROOT=./data

# 数据库文件路径（默认 DATA_ROOT/activation.db）
DB_FILE=./data/activation.db

# 备份目录（默认 DATA_ROOT/backups）
BACKUP_ROOT=./data/backups

# CORS 允许的来源 (生产环境应设置为您的域名)
# CORS_ORIGIN=https://your-domain.com

# HTTPS 配置 (生产环境需要)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem